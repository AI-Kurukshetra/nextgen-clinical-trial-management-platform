# ─── Supabase (required) ────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-url.supabase.co

# Publishable key (new): Supabase Dashboard → API Keys → Publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
# Anon key (fallback): API Keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── S3 / MinIO Object Storage (required for document uploads) ───────────────
# Local dev:  run `docker compose up -d` — MinIO starts on port 9000
# Production: replace with AWS S3, Cloudflare R2, or any S3-compatible service

# MinIO local dev defaults (matches docker-compose.yml)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_BUCKET_NAME=ctms-documents
S3_SIGNATURES_BUCKET_NAME=ctms-signatures
S3_REGION=us-east-1
# Public base URL for serving uploaded files (same as endpoint for MinIO)
NEXT_PUBLIC_S3_PUBLIC_URL=http://localhost:9000/ctms-documents

# ─── Email (required for notifications — Sprint 11) ─────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourctms.com

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
